{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "myTT Profile Data Schema",
  "type": "object",
  "properties": {
    "id": {
      "type": "integer"
    },
    "username": {
      "type": "string"
    },
    "full_name": {
      "type": "string"
    },
    "roles": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "profile": {
      "type": "object",
      "properties": {
        "about_me_markdown": {
          "type": "string"
        },
        "about_me_html": {
          "type": "string"
        },
        "color_banner": {
          "type": "string"
        },
        "private": {
          "type": "boolean"
        },
        "gravatar_uri": {
          "type": "string",
          "format": "uri"
        }
      },
      "required": [
        "about_me_markdown",
        "about_me_html",
        "color_banner",
        "private",
        "gravatar_uri"
      ]
    },
    "created_since": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "id",
    "username",
    "full_name",
    "profile",
    "created_since"
  ]
}